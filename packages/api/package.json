{
  "name": "@great-manut/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "wrangler dev",
    "test": "vitest run",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply great-manut-preview --local",
    "db:migrate:preview": "wrangler d1 migrations apply great-manut-preview --remote",
    "db:migrate:production": "wrangler d1 migrations apply great-manut-prod --env production --remote"
  },
  "dependencies": {
    "@great-manut/core": "workspace:*",
    "hono": "^4.12.26",
    "jose": "^6.0.11",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@cloudflare/workers-types": "^4.20260621.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.103.0"
  }
}
