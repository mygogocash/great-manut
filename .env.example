# Convex — runtime vars are in wrangler.toml [vars]; build script inlines NEXT_PUBLIC_* for the client bundle.
NEXT_PUBLIC_CONVEX_URL=https://sincere-oriole-287.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://sincere-oriole-287.convex.site
CONVEX_DEPLOYMENT=dev:sincere-oriole-287

# OpenNext local preview (.dev.vars uses NEXTJS_ENV instead)
NEXTJS_ENV=development

# After cloning: run `npx convex dev` once (login), then `./scripts/deploy-convex.sh`
# to push auth + backend functions. Set CONVEX_DEPLOY_KEY in GitHub for CI deploys.
# Set CLOUDFLARE_API_TOKEN in GitHub for automatic Cloudflare deploys on push to main.

# Convex Auth — OAuth + post-login redirects (set on Convex deployment, not in wrangler.toml)
# npx convex env set AUTH_GITHUB_ID ...
# npx convex env set AUTH_GITHUB_SECRET ...
# npx convex env set AUTH_GOOGLE_ID ...
# npx convex env set AUTH_GOOGLE_SECRET ...
# npx convex env set SITE_URL http://localhost:3000   # prod: https://app.manut.xyz
# OAuth callback URLs (register in GitHub/Google dashboards):
#   https://sincere-oriole-287.convex.site/api/auth/callback/github
#   https://sincere-oriole-287.convex.site/api/auth/callback/google

# Host split: marketing on manut.xyz, customer app on app.manut.xyz
NEXT_PUBLIC_MARKETING_URL=https://manut.xyz
NEXT_PUBLIC_APP_URL=https://app.manut.xyz

# PostHog — create a "Manut" project at https://us.posthog.com/project/settings
# Client token must be present at build time (NEXT_PUBLIC_*). Set in .env.local and Cloudflare Workers Builds env.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
