# Great Manut environment template
#
# Local development: copy these values to packages/api/.dev.vars
# (wrangler dev loads .dev.vars automatically; the file is gitignored).
#
# Non-secret Worker vars (APP_ENV, JWT_ISSUER, ACCESS_TOKEN_TTL_SECONDS) live in
# packages/api/wrangler.toml. Set production secrets with `wrangler secret put`.

# Required — signs JWT access tokens (use a long random string in production)
JWT_SECRET=great-manut-dev-secret-change-me

# CORS origin for the web dev server (must match apps/web vite port)
APP_ORIGIN=http://localhost:5173

# Optional — Resend magic-code email (production only; dev logs codes to wrangler)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Great Manut <noreply@example.com>
