    "overrides": {
      "dompurify": "3.4.11",
      "postcss": "8.5.15",
      "ws": "8.21.0"
    },
    "allowBuilds": {
      "bufferutil": true,
      "core-js": true,
      "esbuild": true,
      "sharp": true,
      "unrs-resolver": true,
      "utf-8-validate": true,
      "workerd": true
    },
