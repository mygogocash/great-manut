{
  "name": "vector-youtube-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "next dev",
    "dev:backend": "convex dev",
    "build": "NEXT_PUBLIC_CONVEX_URL=https://sincere-oriole-287.convex.cloud NEXT_PUBLIC_CONVEX_SITE_URL=https://sincere-oriole-287.convex.site NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_UM5i50kvCKW8wTXrInMjQrFWzTplgEpTbAm44WxDuBW NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com opennextjs-cloudflare build",
    "build:next": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "pnpm run build:cf && opennextjs-cloudflare preview",
    "deploy": "pnpm run build && wrangler deploy -c wrangler.deploy.toml",
    "deploy:convex": "./scripts/deploy-convex.sh",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "audit:ci": "pnpm audit --audit-level=high",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
